# ─── NEPA Unite Frontend — Environment ───────────────────────────────
# Copy to .env.local and fill in.

# Backend REST API base. JSON API lives under /api/v1; health/docs under /api.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_API_ROOT_URL=http://localhost:8000/api

# Backend "Become a seller" sign-up page. In production point this at the
# deployed host, e.g. https://nepa-unite-mtii.onrender.com/signup/
NEXT_PUBLIC_SIGNUP_URL=http://localhost:8000/signup/

# Public app URL (used by NextAuth & absolute links)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# NextAuth — generate a secret with: openssl rand -base64 32
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=replace-with-a-long-random-string

# Stripe publishable key (optional — frontend also reads it from GET /payments/config)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
